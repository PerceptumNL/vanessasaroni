---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { bags } from '../../data/bags';

export function getStaticPaths() {
  return bags.map((bag) => ({
    params: { slug: bag.slug },
    props: { bag },
  }));
}

const { bag } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title={bag.name} description={`${bag.name} — ${bag.tagline} ${bag.style} by Vanessa Saroni. ${bag.price}.`}>

  <section class="bag-hero">
    <div class="bag-hero__image">
      <img src={bag.image} alt={`${bag.name} — ${bag.style} by Vanessa Saroni`} />
    </div>
    <div class="bag-hero__info">
      <p class="uppercase">{bag.style}</p>
      <h1>{bag.name}</h1>
      <p class="bag-hero__tagline">{bag.tagline}</p>
      <div class="divider"></div>
      <p class="bag-hero__price">{bag.price}</p>
      {bag.stock && bag.stock <= 15 && (
        <p class="bag-hero__stock">Only {bag.stock} remaining</p>
      )}
      <div class="bag-hero__actions">
        <a href="#inquiry" class="btn btn--filled">Inquire About This Piece</a>
        <a href="#inquiry" class="btn">Book a Private Viewing</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="content-block fade-in">
        <div class="content-block__text" style="grid-column: 1 / -1; text-align: center; max-width: 700px; margin: 0 auto;">
          <p class="uppercase">The Story</p>
          <h2>Meet {bag.name}</h2>
          <div class="divider"></div>
          <p>{bag.story}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="background: var(--color-cream);">
    <div class="container">
      <div class="content-block fade-in">
        <div class="content-block__text" style="grid-column: 1 / -1; text-align: center; max-width: 700px; margin: 0 auto;">
          <p class="uppercase">The Fabric</p>
          <h2>What She Is Made Of</h2>
          <div class="divider"></div>
          <p>{bag.fabricStory}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="inquiry">
    <div class="container">
      <div class="inquiry-form fade-in">
        <div class="inquiry-form__intro">
          <p class="uppercase">Get in Touch</p>
          <h2>Interested in {bag.name}?</h2>
          <div class="divider"></div>
          <p>Tell me a bit about yourself and I will get back to you personally. You can also book a private viewing at our Amsterdam studio.</p>
        </div>
        <form class="inquiry-form__form" action="#" method="get">
          <input type="text" name="name" placeholder="Your name" required aria-label="Your name" />
          <input type="email" name="email" placeholder="Your email" required aria-label="Your email" />
          <select name="interest" aria-label="What are you interested in?">
            <option value="inquire">I would like to know more about {bag.name}</option>
            <option value="viewing">I would like to book a private viewing</option>
            <option value="other">Something else</option>
          </select>
          <textarea name="message" placeholder="Anything you would like to share (optional)" rows="4" aria-label="Message"></textarea>
          <button type="submit" class="btn btn--filled">Send</button>
        </form>
      </div>
    </div>
  </section>

  <section class="section text-center">
    <div class="container">
      <h2>Explore More</h2>
      <div class="divider"></div>
      <p style="margin: 0 auto 2rem;">Each bag has her own name and her own story.</p>
      <a href={`${base}/collections`} class="btn">See All Collections</a>
    </div>
  </section>

</BaseLayout>

<style>
  .bag-hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 80vh;
  }

  .bag-hero__image {
    overflow: hidden;
  }

  .bag-hero__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .bag-hero__info {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(2rem, 5vw, 4rem) clamp(2rem, 5vw, 5rem);
  }

  .bag-hero__info h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    margin-bottom: 0.5rem;
  }

  .bag-hero__tagline {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.2rem;
    color: var(--color-charcoal);
    margin-bottom: 1.5rem;
  }

  .bag-hero__price {
    font-family: var(--font-sans);
    font-size: 1.1rem;
    letter-spacing: 0.05em;
    color: var(--color-gold);
    margin-bottom: 0.5rem;
  }

  .bag-hero__stock {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-terracotta);
    margin-bottom: 1.5rem;
  }

  .bag-hero__actions {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    margin-top: 1rem;
    max-width: 300px;
  }

  .bag-hero__actions .btn--filled {
    background: var(--color-black);
    color: var(--color-warm-white);
    border-color: var(--color-black);
    text-align: center;
  }

  .bag-hero__actions .btn--filled:hover {
    background: var(--color-charcoal);
    border-color: var(--color-charcoal);
  }

  .bag-hero__actions .btn {
    text-align: center;
  }

  /* Inquiry Form */
  .inquiry-form {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
  }

  .inquiry-form__intro {
    margin-bottom: 2.5rem;
  }

  .inquiry-form__intro p:last-of-type {
    max-width: 500px;
    margin: 1rem auto 0;
    opacity: 0.7;
  }

  .inquiry-form__form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-align: left;
  }

  .inquiry-form__form input,
  .inquiry-form__form select,
  .inquiry-form__form textarea {
    border: 1px solid rgba(0, 0, 0, 0.15);
    padding: 0.9rem 1.2rem;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    background: var(--color-warm-white);
    outline: none;
    transition: border-color 0.3s ease;
    width: 100%;
  }

  .inquiry-form__form input:focus,
  .inquiry-form__form select:focus,
  .inquiry-form__form textarea:focus {
    border-color: var(--color-gold);
  }

  .inquiry-form__form .btn--filled {
    background: var(--color-black);
    color: var(--color-warm-white);
    border-color: var(--color-black);
    cursor: pointer;
    align-self: flex-start;
    padding: 0.9rem 3rem;
  }

  .inquiry-form__form .btn--filled:hover {
    background: var(--color-charcoal);
    border-color: var(--color-charcoal);
  }

  @media (max-width: 768px) {
    .bag-hero {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .bag-hero__image {
      aspect-ratio: 1;
    }
  }
</style>

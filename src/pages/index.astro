---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Bold & Brave">

  <!-- Hero Section -->
  <section class="hero">
    <img src="https://www.vanessasaroni.com/cdn/shop/files/Capodanno_1400x.jpg?v=1734195219" alt="Vanessa Saroni luxury handcrafted bag" class="hero__image" />
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <p class="uppercase hero__pre">Born in Brazil · Made in Italy · Designed in Amsterdam</p>
      <h1>Bold & Brave</h1>
      <div class="divider" style="background: var(--color-warm-white);"></div>
      <p class="hero__sub">Handwoven by women artisans, crafted into luxury. No two pieces are exactly alike.</p>
      <a href={`${base}/collections`} class="btn hero__btn">Discover the Collection</a>
    </div>
  </section>

  <!-- Values Pillars -->
  <section class="section">
    <div class="container">
      <div class="values-grid fade-in">
        <div class="values-grid__item">
          <h3>Woven by Hand</h3>
          <div class="divider"></div>
          <p>Each metre of fabric takes a full day to produce. Our artisans in Brazil weave every thread on traditional looms, by hand.</p>
        </div>
        <div class="values-grid__item">
          <h3>Made by Women</h3>
          <div class="divider"></div>
          <p>This brand exists because of the women who weave, who design, who build. Their skill and independence are woven into every bag.</p>
        </div>
        <div class="values-grid__item">
          <h3>Built to Last</h3>
          <div class="divider"></div>
          <p>We design for years, not seasons. Handwoven cotton, Italian craftsmanship, and materials that age beautifully.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Collections -->
  <section class="section collections-preview">
    <div class="container text-center">
      <p class="uppercase">Discover</p>
      <h2>Our Collections</h2>
      <div class="divider"></div>
    </div>
    <div class="container--wide collections-grid fade-in">
      <a href={`${base}/collections`} class="collection-card img-hover">
        <img src="https://www.vanessasaroni.com/cdn/shop/files/Juju_tartan_collection_vanessa_saroni_535831b3-8057-403e-8f79-3693254f8577_1400x.jpg?v=1614326105" alt="Tartan Collection" loading="lazy" />
        <div class="collection-card__info">
          <h3>Tartan</h3>
          <span class="uppercase">Explore</span>
        </div>
      </a>
      <a href={`${base}/collections`} class="collection-card img-hover">
        <img src="https://www.vanessasaroni.com/cdn/shop/files/Vanessa_Saroni_-_Linda_Piano_Collection_Off_White_1400x.jpg?v=1614326016" alt="Piano Collection" loading="lazy" />
        <div class="collection-card__info">
          <h3>Piano</h3>
          <span class="uppercase">Explore</span>
        </div>
      </a>
      <a href={`${base}/collections`} class="collection-card img-hover">
        <img src="https://www.vanessasaroni.com/cdn/shop/files/X3-01_e5f6b035-4844-4d3a-b7cd-c7e38e331c32_1400x.jpg?v=1661776410" alt="Colorcore Collection" loading="lazy" />
        <div class="collection-card__info">
          <h3>Colorcore</h3>
          <span class="uppercase">Explore</span>
        </div>
      </a>
      <a href={`${base}/collections`} class="collection-card img-hover">
        <img src="https://www.vanessasaroni.com/cdn/shop/files/X2-01_1400x.jpg?v=1661772900" alt="Lyric Collection" loading="lazy" />
        <div class="collection-card__info">
          <h3>Lyric</h3>
          <span class="uppercase">Explore</span>
        </div>
      </a>
    </div>
  </section>

  <!-- Quote -->
  <section class="quote">
    <div class="container">
      <blockquote class="fade-in">
        "The imperfections are not flaws. They are proof that a person made this, not a machine."
      </blockquote>
      <cite>Vanessa Saroni</cite>
    </div>
  </section>

  <!-- Brand Story Preview -->
  <section class="section">
    <div class="container">
      <div class="content-block fade-in">
        <div class="content-block__image img-hover">
          <img src={`${base}/images/our-women-1.jpg`} alt="Vanessa Saroni artisan craftsmanship" loading="lazy" />
        </div>
        <div class="content-block__text">
          <p class="uppercase">Our World</p>
          <h2>A Mosaic of Cultures</h2>
          <p>My designs begin in Amsterdam, draw from my Brazilian roots, and come to life in Italian workshops. But really, they start with the women I work with. The artisans, the artists, the friends. That connection is what makes each piece what it is.</p>
          <a href={`${base}/our-world`} class="btn">Meet the Women Behind the Brand</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Products -->
  <section class="section featured-products" style="background: var(--color-cream);">
    <div class="container text-center">
      <p class="uppercase">Meet the Bags</p>
      <h2>Each One Has a Name</h2>
      <div class="divider"></div>
    </div>
    <div class="container products-grid fade-in">
      <a href={`${base}/bags/juju`} class="product-card img-hover">
        <img src="https://www.vanessasaroni.com/cdn/shop/files/Juju_tartan_collection_vanessa_saroni_535831b3-8057-403e-8f79-3693254f8577_1400x.jpg?v=1614326105" alt="JUJU bag" loading="lazy" />
        <div class="product-card__info">
          <h4>Juju</h4>
          <p class="product-card__tagline">Class used to be priceless.</p>
          <span>From &euro;675</span>
        </div>
      </a>
      <a href={`${base}/bags/lola`} class="product-card img-hover">
        <img src="https://www.vanessasaroni.com/cdn/shop/products/FW-91-890938_400x.jpg?v=1632528913" alt="LOLA bag" loading="lazy" />
        <div class="product-card__info">
          <h4>Lola</h4>
          <p class="product-card__tagline">Effortless. Always.</p>
          <span>From &euro;595</span>
        </div>
      </a>
      <a href={`${base}/bags/duda`} class="product-card img-hover">
        <img src="https://www.vanessasaroni.com/cdn/shop/products/VanessaSaroni_20220719_E-Commerce_53-2_400x.jpg?v=1665649996" alt="DUDA bag" loading="lazy" />
        <div class="product-card__info">
          <h4>Duda</h4>
          <p class="product-card__tagline">For the woman who carries her world with her.</p>
          <span>From &euro;645</span>
        </div>
      </a>
      <a href={`${base}/bags/karol`} class="product-card img-hover">
        <img src="https://www.vanessasaroni.com/cdn/shop/products/FW-11-316104_400x.jpg?v=1632788509" alt="KAROL 3-in-1 bag" loading="lazy" />
        <div class="product-card__info">
          <h4>Karol</h4>
          <p class="product-card__tagline">3 bags in 1. What else?</p>
          <span>From &euro;595</span>
        </div>
      </a>
    </div>
    <div class="container text-center" style="margin-top: 3rem;">
      <a href={`${base}/collections`} class="btn">Explore All Designs</a>
    </div>
  </section>

  <!-- Sustainability Preview -->
  <section class="section">
    <div class="container">
      <div class="content-block content-block--reverse fade-in">
        <div class="content-block__image img-hover">
          <img src={`${base}/images/our-women-2.jpg`} alt="Brazilian artisan weaving fabric" loading="lazy" />
        </div>
        <div class="content-block__text">
          <p class="uppercase">How We Make</p>
          <h2>No Factories. Just Hands.</h2>
          <p>Our fabrics are 100% handwoven. No industrial looms, no excess electricity, no water waste. When you hold one of our bags, you are holding hours of someone's focused, skilled, quiet work.</p>
          <a href={`${base}/sustainability`} class="btn">How It All Comes Together</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Press -->
  <section class="press section" style="background: var(--color-cream);">
    <div class="container text-center">
      <p class="uppercase">As Seen In</p>
      <div class="press__logos fade-in">
        <span class="press__item">Marie Claire Italia</span>
        <span class="press__item">Sfilate</span>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
  }

  .hero__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(26, 26, 26, 0.15) 0%,
      rgba(26, 26, 26, 0.4) 50%,
      rgba(26, 26, 26, 0.6) 100%
    );
  }

  .hero__content {
    position: relative;
    z-index: 1;
    padding: 2rem;
  }

  .hero__pre {
    margin-bottom: 1.5rem;
    color: var(--color-gold);
  }

  .hero h1 {
    font-size: clamp(3.5rem, 8vw, 7rem);
    font-weight: 400;
    font-style: italic;
    color: var(--color-warm-white);
    margin-bottom: 0.5rem;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.2);
  }

  .hero__sub {
    font-size: clamp(1rem, 1.3vw, 1.2rem);
    color: var(--color-warm-white);
    margin: 1.5rem auto 2.5rem;
    max-width: 500px;
    opacity: 0.9;
  }

  .hero__btn {
    border-color: var(--color-warm-white);
    color: var(--color-warm-white);
  }

  .hero__btn:hover {
    background: var(--color-warm-white);
    color: var(--color-black);
  }

  /* Collections Grid */
  .collections-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-top: 3rem;
    padding: 0 clamp(1.5rem, 4vw, 3rem);
    max-width: var(--container-wide);
    margin-left: auto;
    margin-right: auto;
  }

  .collection-card {
    position: relative;
    display: block;
    aspect-ratio: 3/4;
    overflow: hidden;
  }

  .collection-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .collection-card__info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 2rem 1.5rem;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
    color: white;
  }

  .collection-card__info h3 {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    color: white;
    margin-bottom: 0.3rem;
  }

  .collection-card__info .uppercase {
    font-size: 0.65rem;
    opacity: 0.8;
    color: white;
  }

  /* Products Grid */
  .products-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    margin-top: 3rem;
  }

  .product-card {
    display: block;
    text-align: center;
  }

  .product-card img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    margin-bottom: 1rem;
  }

  .product-card__info h4 {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    margin-bottom: 0.3rem;
  }

  .product-card__tagline {
    font-style: italic;
    font-size: 0.85rem;
    opacity: 0.6;
    margin-bottom: 0.3rem;
  }

  .product-card__info span {
    font-size: 0.85rem;
    color: var(--color-gold);
  }

  /* Press */
  .press__logos {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 4rem;
    margin-top: 2rem;
  }

  .press__item {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-style: italic;
    color: var(--color-charcoal);
    opacity: 0.5;
  }

  @media (max-width: 900px) {
    .collections-grid {
      grid-template-columns: 1fr 1fr;
    }

    .products-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 600px) {
    .collections-grid {
      grid-template-columns: 1fr;
    }

    .products-grid {
      grid-template-columns: 1fr 1fr;
    }

    .hero {
      min-height: 70vh;
    }
  }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Our World" description="Discover the world of Vanessa Saroni — our women, our fabrics, our process. Handcrafted luxury made by women, for women.">

  <section class="page-header">
    <div class="container">
      <p class="uppercase">Discover</p>
      <h1>Our World</h1>
      <div class="divider"></div>
      <p>The women, the fabrics, and the places that shape everything we make.</p>
    </div>
  </section>

  <!-- Our Women -->
  <section class="section">
    <div class="container">
      <div class="content-block fade-in">
        <div class="content-block__image img-hover">
          <img src={`${base}/images/our-women-1.jpg`} alt="Vanessa Saroni and her team of women artisans" loading="lazy" />
        </div>
        <div class="content-block__text">
          <p class="uppercase">Our Women</p>
          <h2>Made by Women, for Women</h2>
          <p>I started this brand because I wanted to build something with the women around me, not just for them. The artisans who weave our fabrics in Brazil, the craftspeople in Italy who assemble each bag, the artists I collaborate with: they are not suppliers. They are the brand.</p>
          <p>When a woman buys one of our bags, she is holding the work of other women who gained independence through their craft. That is not a tagline. That is what actually happens.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Fabrics -->
  <section class="section" style="background: var(--color-cream);">
    <div class="container">
      <div class="content-block content-block--reverse fade-in">
        <div class="content-block__image img-hover">
          <img src={`${base}/images/our-women-2.jpg`} alt="Hand weaving artisan fabrics" loading="lazy" />
        </div>
        <div class="content-block__text">
          <p class="uppercase">Our Fabrics</p>
          <h2>One Day Per Metre</h2>
          <p>That is how long it takes to weave our fabric. One metre, one day, one pair of hands on a traditional loom. The threads are cotton, silk, and wool, exclusively produced for us. Each colour and pattern is custom-designed for a specific collection.</p>
          <p>No two pieces of fabric are identical. The slight variations in tension, in colour depth, in the way the weft catches the light: those are not imperfections. They are proof of origin.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Process -->
  <section class="section">
    <div class="container">
      <div class="content-block fade-in">
        <div class="content-block__text" style="grid-column: 1 / -1; text-align: center; max-width: 800px; margin: 0 auto;">
          <p class="uppercase">Our Process</p>
          <h2>From Thread to Bag</h2>
          <div class="divider"></div>
          <p style="margin: 0 auto;">I was born in Brazil, fell in love with Italy, and now live in Amsterdam. My bags are a product of all three places. The weaving traditions of my homeland, the leather craftsmanship of Italy, and the design sensibility I found on the canals.</p>
        </div>
      </div>

      <div class="process-grid fade-in">
        <div class="process-step">
          <span class="process-step__number">01</span>
          <h3>Design</h3>
          <p>Each collection starts with an idea, a colour, a conversation. I draw from my Brazilian-Italian heritage and from the artists I meet along the way.</p>
        </div>
        <div class="process-step">
          <span class="process-step__number">02</span>
          <h3>Weave</h3>
          <p>Our artisans in Brazil hand-weave every metre of fabric using traditional techniques passed down through generations.</p>
        </div>
        <div class="process-step">
          <span class="process-step__number">03</span>
          <h3>Craft</h3>
          <p>In Italy, skilled craftspeople turn our handwoven fabric into bags. Italian precision meets Brazilian texture.</p>
        </div>
        <div class="process-step">
          <span class="process-step__number">04</span>
          <h3>Deliver</h3>
          <p>Each bag ships from our Amsterdam studio to you. Worldwide, with care, and with a handwritten note.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Collaboration Quote -->
  <section class="quote">
    <div class="container">
      <blockquote class="fade-in">
        "Something truly unique can only be achieved by the work and collaboration of restless individuals."
      </blockquote>
      <cite>Vanessa Saroni</cite>
    </div>
  </section>

  <!-- CTA -->
  <section class="section text-center">
    <div class="container">
      <h2>Meet the Bags</h2>
      <div class="divider"></div>
      <p style="margin: 0 auto 2rem;">Each one has a name, a story, and a character of her own.</p>
      <a href={`${base}/collections`} class="btn">Explore the Collection</a>
    </div>
  </section>

</BaseLayout>

<style>
  .process-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2.5rem;
    margin-top: 4rem;
    text-align: center;
  }

  .process-step {
    padding: 2rem 1rem;
  }

  .process-step__number {
    font-family: var(--font-serif);
    font-size: 2.5rem;
    color: var(--color-gold);
    opacity: 0.4;
    display: block;
    margin-bottom: 1rem;
  }

  .process-step h3 {
    font-size: 1.3rem;
    margin-bottom: 0.8rem;
  }

  .process-step p {
    font-size: 0.9rem;
    opacity: 0.7;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .process-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 480px) {
    .process-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
